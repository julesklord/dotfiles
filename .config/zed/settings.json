// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "show_wrap_guides": true,
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "which_key": {
    "enabled": false
  },
  "inlay_hints": {
    "enabled": true
  },
  "indent_guides": {
    "background_coloring": "indent_aware"
  },
  "toolbar": {
    "code_actions": true
  },
  "minimap": {
    "show": "auto"
  },
  "git_panel": {
    "dock": "left",
    "show_count_badge": true,
    "tree_view": false,
    "file_icons": true
  },
  "agent_buffer_font_size": 12.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "context_servers": {
    "mcp-server-code-runner": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "REDACTED_SET_VIA_ENV_OR_ZED_SECRETS"
      }
    },
    "mcp-server-memory": {
      "enabled": true,
      "remote": false,
      "settings": {
        "memory_file_path": ""
      }
    },
    "mcp-server-slack": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-repomix": {
      "enabled": true,
      "remote": false,
      "settings": {
        "repomix_path": ""
      }
    },
    "arch-ops-server": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-markitdown": {
      "enabled": true,
      "remote": false,
      "settings": {
        "package_version": "latest"
      }
    },
    "mcp-server-mui": {
      "enabled": true,
      "remote": false,
      "settings": {
        "preferred_theme": "",
        "component_filter": [
          ""
        ]
      }
    },
    "browser-tools-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-brave-search": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "title_bar": {
    "button_layout": "standard",
    "show_menus": false,
    "show_branch_status_icon": true
  },
  "status_bar": {
    "line_endings_button": true,
    "show_active_file": false,
    "active_encoding_button": "non_utf8"
  },
  "proxy": "",
  "agent": {
    "dock": "right",
    "limit_content_width": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": true,
      "effort": "high"
    },
    "show_turn_stats": true,
    "play_sound_when_agent_done": "when_hidden",
    "favorite_models": [],
    "single_file_review": true,
    "model_parameters": []
  },
  "document_folding_ranges": "on",
  "document_symbols": "on",
  "agent_ui_font_size": 13.0,
  "buffer_line_height": "standard",
  "window_decorations": "server",
  "use_system_window_tabs": false,
  "bottom_dock_layout": "right_aligned",
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true
  },
  "tab_bar": {
    "show": true,
    "show_pinned_tabs_in_separate_row": true
  },
  "tabs": {
    "show_diagnostics": "errors",
    "activate_on_close": "history",
    "file_icons": true,
    "git_status": true
  },
  "project_panel": {
    "dock": "left",
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "entry_spacing": "standard",
    "button": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "prettier": {
    "allowed": true
  },
  "auto_signature_help": true,
  "autosave": "on_focus_change",
  "terminal": {
    "show_count_badge": true,
    "font_weight": 550.0,
    "font_family": ".ZedMono",
    "scrollbar": {
      "show": "never"
    },
    "default_width": 640.0,
    "toolbar": {
      
    },
    "shell": {
      "program": "fish"
    },
    "font_size": 12.0
  },
  "buffer_font_weight": 550.0,
  "cli_default_open_behavior": "new_window",
  "edit_predictions": {
    "open_ai_compatible_api": {
      "model": ""
    },
    "ollama": {
      "max_output_tokens": 128,
      "prompt_format": "qwen",
      "api_url": "http://localhost:11434",
      "model": "qwen2.5-coder:7b-base"
    },
    "provider": "zed"
  },
  "text_rendering_mode": "grayscale",
  "buffer_font_family": "FiraCode Nerd Font Propo",
  "icon_theme": "Bearded Icon Theme",
  "ui_font_family": "Arimo Nerd Font Propo",
  "ui_font_weight": 550.0,
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "build",
        "model": "nvidia/moonshotai/kimi-k2.6"
      },
      "type": "registry"
    },
    "gemini": {
      "default_mode": "yolo",
      "default_model": "gemini-3.1-pro-preview",
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 12.0,
  "theme": "DankShell Dark Transparent",
}
