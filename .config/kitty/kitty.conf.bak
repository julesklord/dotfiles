# --- Font Configuration ---
font_size 10.0

# BEGIN_KITTY_FONTS
font_family      family="Terminess Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS

# --- Window Configuration ---
window_padding_width 12
window_margin_width 0
single_window_margin_width -1
background_opacity 0.95
background_blur 32
hide_window_decorations yes
confirm_os_window_close 0
remember_window_size  yes
initial_window_width  1000
initial_window_height 650

# --- Cursor Configuration ---
cursor_shape block
cursor_blink_interval 0.5
cursor_stop_blinking_after 15.0

# Visual Tune: Cursor Trail (Modern/Flashy)
cursor_trail 3
cursor_trail_decay 0.1 0.4
cursor_trail_start_threshold 2

# --- Scrollback ---
scrollback_lines 5000
wheel_scroll_multiplier 5.0
touch_scroll_multiplier 1.0

# --- Terminal features ---
copy_on_select yes
strip_trailing_spaces smart
url_style curly
open_url_with default
detect_urls yes
sync_to_monitor yes
enable_audio_bell no
visual_bell_duration 0.0

# --- Layouts ---
enabled_layouts splits,stack,tall,fat,grid

# --- Key bindings ---
# General
map ctrl+f5 load_config_file
map ctrl+shift+plus change_font_size all +1.0
map ctrl+shift+minus change_font_size all -1.0
map ctrl+shift+backspace change_font_size all 0

# Windows & Tabs
map ctrl+shift+n new_os_window
map ctrl+t new_tab_with_cwd
map ctrl+shift+enter launch --location=split --cwd=current
map ctrl+shift+w close_window

# Navigation (Alt + Arrows)
map alt+left neighboring_window left
map alt+right neighboring_window right
map alt+up neighboring_window up
map alt+down neighboring_window down

# Productivity
map ctrl+shift+z toggle_layout stack
map ctrl+shift+l next_layout
map ctrl+shift+s layout_action rotate

# Remote Control
allow_remote_control yes
listen_on unix:/tmp/mykitty

# --- Includes ---
# Dank color generation
include dank-tabs.conf
include dank-theme.conf

# BEGIN_KITTY_THEME
# Flexoki (Dark)
include current-theme.conf
# END_KITTY_THEME
